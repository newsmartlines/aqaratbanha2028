{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "node -e \"const h=require('http');h.createServer((req,res)=>{const p=h.request({host:'localhost',port:20787,path:req.url,method:req.method,headers:{...req.headers,host:'localhost:20787'}},r=>{res.writeHead(r.statusCode,r.headers);r.pipe(res)});req.on('error',()=>{});p.on('error',()=>{try{res.writeHead(502);res.end('Gateway starting...')}catch(_){}});req.pipe(p)}).listen(5000,()=>console.log('proxy 5000->20787 ready'))\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:deploy": "pnpm --filter @workspace/marketplace run build && pnpm --filter @workspace/api-server run build",
    "start:deploy": "cross-env NODE_ENV=production node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
