modules = ["nodejs-20", "php-8.2", "web", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["pnpm", "run", "start:deploy"]
build = ["pnpm", "run", "build:deploy"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev & pnpm --filter @workspace/marketplace run dev & node health-server.mjs & wait"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 20787
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
STCPAY_TEST_MODE = "true"
PORT = "8080"
VITE_PORT = "5000"
NODE_ENV = "development"
LOG_LEVEL = "info"
