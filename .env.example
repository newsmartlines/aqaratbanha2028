# ============================================================
# Environment Variables — copy this file to .env and fill in
# ============================================================
#
# ⚠  Never commit a filled-in .env file to version control.
# ⚠  All secrets must be set via your platform's secret manager
#    (Replit Secrets, Doppler, AWS Secrets Manager, etc.).

# ── Server ──────────────────────────────────────────────────
# Port the API server listens on
PORT=8080

# "development" or "production" — controls security settings,
# CORS policy, cookie flags, rate limiting, and more.
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string.
# On Replit this is managed automatically — do not set it manually.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql://postgres:password@localhost:5432/aqaratbanha

# ── Frontend Dev Server (development only) ───────────────────
# Port for the Vite dev server (used by the reverse proxy in dev)
VITE_PORT=5000

# URL of the API server (used by Vite proxy in development only)
API_SERVER_URL=http://localhost:8080

# ── Frontend Production (production only) ────────────────────
# If the frontend is hosted on a different domain than the API,
# set this to the full URL of the API server.
# Leave empty if frontend and API are served from the same domain.
# VITE_API_BASE_URL=https://api.yourdomain.com

# Path to the built frontend directory (optional override)
# Default: artifacts/marketplace/dist/public
# FRONTEND_DIST=/var/www/html/dist/public

# ── File Uploads ─────────────────────────────────────────────
# Absolute path where uploaded files are stored.
# Default: <project-root>/uploads
UPLOADS_DIR=/home/runner/workspace/uploads

# ── CORS ─────────────────────────────────────────────────────
# Allowed cross-origin request sources (comma-separated, no spaces).
#
# Rules enforced automatically by the server:
#   • NODE_ENV=development  → all origins allowed (safe locally)
#   • NODE_ENV=production   → only the origins listed here are allowed
#   • "*" is treated as "not set" — wildcard CORS is never used with credentials
#
# Examples:
#   Single domain:   CORS_ORIGIN=https://aqaratbanha.com
#   Multiple domains: CORS_ORIGIN=https://aqaratbanha.com,https://www.aqaratbanha.com
#   With staging:    CORS_ORIGIN=https://aqaratbanha.com,https://staging.aqaratbanha.com
#
# CORS_ORIGIN=https://aqaratbanha.com,https://www.aqaratbanha.com

# ── Auth / Security ──────────────────────────────────────────
# Secret used to sign HMAC tokens and verify session integrity.
#
# REQUIREMENTS (enforced at startup in production):
#   • Must be set — the server refuses to start in production without it
#   • Minimum 64 characters of cryptographic randomness
#   • Must not be a placeholder like "change-me" or "secret"
#
# Generate a strong secret (run once in your terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   openssl rand -hex 48
#
# SESSION_SECRET=<output of the command above>

# ── Google OAuth (optional) ──────────────────────────────────
# Required only if you want Google Sign-In.
# Create credentials at https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxx

# ── Email / SMTP (optional) ──────────────────────────────────
# Configure in Admin → Settings → Email after deploying.
# SMTP settings are stored in the database, not here.

# ── OpenAI (optional) ────────────────────────────────────────
# Enables AI-assisted email generation in the Admin panel.
# Without this key, a static fallback is used automatically.
# OPENAI_API_KEY=sk-...

# ── Payment Gateways (optional) ──────────────────────────────
# Configure in Admin → Settings → Payments after deploying.
# Payment settings (Vodafone Cash, InstaPay, etc.) are stored in the DB.

# ── Logging ──────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
