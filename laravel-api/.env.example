APP_NAME="دليل الخدمات"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=daleel_db
DB_USERNAME=daleel_user
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,yourdomain.com

# File Upload
MAX_UPLOAD_SIZE=5120

# STC Pay
STCPAY_MERCHANT_ID=
STCPAY_API_KEY=
STCPAY_BASE_URL=https://api.stcpay.com.sa
STCPAY_TEST_MODE=true
STCPAY_RETURN_URL=https://yourdomain.com/api/stcpay/return

# Commission
DEFAULT_COMMISSION_RATE=10
