{
  "info": {
    "name": "دليل الخدمات API",
    "description": "Laravel API for Daleel Services Marketplace",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.yourdomain.com/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"أحمد\",\"email\":\"ahmed@example.com\",\"password\":\"Secret@123\",\"password_confirmation\":\"Secret@123\"}" }
          }
        },
        {
          "name": "Register Provider",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/provider",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"محمد\",\"email\":\"provider@example.com\",\"phone\":\"0501234567\",\"password\":\"Secret@123\",\"password_confirmation\":\"Secret@123\",\"business_name\":\"شركة المثال\",\"category_id\":1,\"region_id\":1,\"city_id\":1}" }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": ["var r = pm.response.json(); if(r.data && r.data.token) pm.collectionVariables.set('token', r.data.token);"], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@daleel.sa\",\"password\":\"Admin@123456\"}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        { "name": "Categories", "request": { "method": "GET", "url": "{{base_url}}/categories" } },
        { "name": "Regions", "request": { "method": "GET", "url": "{{base_url}}/regions" } },
        { "name": "Packages", "request": { "method": "GET", "url": "{{base_url}}/packages" } },
        { "name": "Public Settings", "request": { "method": "GET", "url": "{{base_url}}/settings" } },
        { "name": "Providers", "request": { "method": "GET", "url": "{{base_url}}/providers?per_page=10" } },
        { "name": "Provider Detail", "request": { "method": "GET", "url": "{{base_url}}/providers/1" } },
        { "name": "Nearby Providers", "request": { "method": "POST", "url": "{{base_url}}/providers/nearby", "body": { "mode": "raw", "raw": "{\"latitude\":24.7136,\"longitude\":46.6753,\"radius\":20}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Services", "request": { "method": "GET", "url": "{{base_url}}/services" } }
      ]
    },
    {
      "name": "Provider (auth: provider)",
      "item": [
        { "name": "My Profile", "request": { "method": "GET", "url": "{{base_url}}/provider/profile", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "Stats", "request": { "method": "GET", "url": "{{base_url}}/provider/stats", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "Create Service", "request": { "method": "POST", "url": "{{base_url}}/provider/services", "header": [{"key":"Authorization","value":"Bearer {{token}}"},{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"title\":\"تسليك مجاري\",\"description\":\"خدمة احترافية\",\"price\":150,\"price_type\":\"fixed\"}" } } }
      ]
    },
    {
      "name": "Requests",
      "item": [
        { "name": "My Requests", "request": { "method": "GET", "url": "{{base_url}}/requests", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "Create Request", "request": { "method": "POST", "url": "{{base_url}}/requests", "header": [{"key":"Authorization","value":"Bearer {{token}}"},{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"provider_id\":1,\"title\":\"إصلاح تسرب\",\"description\":\"...\",\"budget\":300}" } } },
        { "name": "Update Status", "request": { "method": "PUT", "url": "{{base_url}}/requests/1/status", "header": [{"key":"Authorization","value":"Bearer {{token}}"},{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"status\":\"accepted\"}" } } }
      ]
    },
    {
      "name": "STC Pay",
      "item": [
        { "name": "Initiate Subscription", "request": { "method": "POST", "url": "{{base_url}}/stcpay/subscription", "header": [{"key":"Authorization","value":"Bearer {{token}}"},{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"package_id\":2,\"billing_cycle\":\"monthly\"}" } } },
        { "name": "Check Status", "request": { "method": "GET", "url": "{{base_url}}/stcpay/status/PAY-XXXXXXXXXX", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } }
      ]
    },
    {
      "name": "Admin",
      "item": [
        { "name": "Dashboard Stats", "request": { "method": "GET", "url": "{{base_url}}/admin/stats", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "All Providers", "request": { "method": "GET", "url": "{{base_url}}/admin/providers?status=pending", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "Approve Provider", "request": { "method": "POST", "url": "{{base_url}}/admin/providers/1/approve", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "Reject Provider", "request": { "method": "POST", "url": "{{base_url}}/admin/providers/1/reject", "header": [{"key":"Authorization","value":"Bearer {{token}}"},{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"reason\":\"بيانات غير مكتملة\"}" } } },
        { "name": "Payments", "request": { "method": "GET", "url": "{{base_url}}/admin/payments", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } },
        { "name": "All Users", "request": { "method": "GET", "url": "{{base_url}}/admin/users", "header": [{"key":"Authorization","value":"Bearer {{token}}"}] } }
      ]
    }
  ]
}
